# App
APP_ENV=development
APP_NAME=Together API
APP_VERSION=v1
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://together:together@localhost:5432/together_db
DATABASE_URL_SYNC=postgresql+psycopg2://together:together@localhost:5432/together_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=CHANGE_ME_SUPER_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# OpenAI (AI Module - futuro)
OPENAI_API_KEY=

# AWS (futuro)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
